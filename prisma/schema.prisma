generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Session {
  id                  String    @id
  shop                String
  state               String
  isOnline            Boolean   @default(false)
  scope               String?
  expires             DateTime?
  accessToken         String
  userId              BigInt?
  firstName           String?
  lastName            String?
  email               String?
  accountOwner        Boolean   @default(false)
  locale              String?
  collaborator        Boolean?  @default(false)
  emailVerified       Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

model TransitRule {
  id          String @id @default(cuid())
  keyword     String @unique
  transitDays Int
}

model WeatherCache {
  id        String   @id @default(cuid())
  zip       String
  date      String
  maxTempF  Float
  minTempF  Float?
  cachedAt  DateTime @default(now())

  @@unique([zip, date])
}

model AppSettings {
  id                String  @id @default("singleton")
  dontShipAbove     Int     @default(90)
  icePackAbove      Int     @default(80)
  dontShipBelow     Int     @default(35)
  cautionBelow      Int     @default(45)
  printLocalOrders  Boolean @default(false)
  rolloverEnabled   Boolean @default(true)
  delayEmailTemplate String @default("")
}

model TransitCache {
  id       String   @id @default(cuid())
  zip      String
  method   String
  date     String
  days     Int
  cachedAt DateTime @default(now())

  @@unique([zip, method, date])
}
