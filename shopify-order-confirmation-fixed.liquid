{% assign delivery_method_types = delivery_agreements | map: 'delivery_method_type' | uniq %}
{% if delivery_method_types.size > 1 %}
  {% assign has_split_cart = true %}
{% else %}
  {% assign has_split_cart = false %}
{% endif %}

{% capture email_title %}
  {% if has_pending_payment %}
    Thank you for your order!
  {% else %}
    Thank you for your purchase!
  {% endif %}
{% endcapture %}

{% comment %} ── Corrected Ship Date Calculation ──
Matches the app's nextShipDate() logic:
- Mon/Tue before 1 PM CT → ship today
- Mon after 1 PM CT → ship Tue
- Tue after 1 PM CT → ship Wed (restricted)
- Wed-Sun → ship next week's Mon
{% endcomment %}

{% assign order_dow  = order.created_at | date: "%u" %}
{% assign order_hour = order.created_at | date: "%H" | plus: 0 %}
{% assign seconds_per_day = 86400 %}

{% comment %} Federal holidays (keep in sync with app) {% endcomment %}
{% assign holidays = "2026-01-01,2026-01-19,2026-02-16,2026-05-25,2026-07-03,2026-09-07,2026-10-12,2026-11-11,2026-11-26,2026-12-25,2027-01-01,2027-01-18,2027-02-15,2027-05-31,2027-07-05,2027-09-06,2027-10-11,2027-11-11,2027-11-25,2027-12-24,2027-12-31" %}

{% assign order_ymd = order.created_at | date: "%Y-%m-%d" %}
{% assign ship_ymd = order_ymd %}
{% assign days_to_add = 0 %}
{% assign is_wednesday_only = false %}

{% comment %} Mon or Tue before 1 PM → ship today {% endcomment %}
{% if order_dow == "1" or order_dow == "2" %}
  {% if order_hour < 13 %}
    {% assign ship_ymd = order_ymd %}
  {% else %}
    {% if order_dow == "1" %}
      {% assign days_to_add = 1 %}
    {% elsif order_dow == "2" %}
      {% assign days_to_add = 1 %}
      {% assign is_wednesday_only = true %}
    {% endif %}
  {% endif %}
{% else %}
  {% comment %} Wed-Sun → next week's Monday {% endcomment %}
  {% assign days_until_mon = 1 %}
  {% if order_dow == "3" %}{% assign days_until_mon = 5 %}
  {% elsif order_dow == "4" %}{% assign days_until_mon = 4 %}
  {% elsif order_dow == "5" %}{% assign days_until_mon = 3 %}
  {% elsif order_dow == "6" %}{% assign days_until_mon = 2 %}
  {% elsif order_dow == "7" %}{% assign days_until_mon = 1 %}
  {% endif %}
  {% assign days_to_add = days_until_mon %}
{% endif %}

{% comment %} Calculate final ship date and skip holidays {% endcomment %}
{% assign ship_seconds = order_ymd | append: " 12:00:00" | date: "%s" | plus: 0 %}
{% assign days_offset = days_to_add | times: seconds_per_day %}
{% assign ship_seconds = ship_seconds | plus: days_offset %}
{% for i in (1..3) %}
  {% assign test_ymd = ship_seconds | date: "%Y-%m-%d" %}
  {% if holidays contains test_ymd %}
    {% assign ship_seconds = ship_seconds | plus: seconds_per_day %}
  {% endif %}
{% endfor %}

{% assign ship_date = ship_seconds | date: "%A, %B %d, %Y" %}

{% capture email_body %}
  {% if has_pending_payment %}
    {% if buyer_action_required %}
      You'll get a confirmation email after completing your payment.
    {% else %}
      Your payment is being processed. You'll get an email when your order is confirmed.
    {% endif %}
  {% else %}
    {% if requires_shipping %}
      {% case delivery_method %}
        {% when 'pick-up' %}
          You'll receive an email when your order is ready for pickup.
        {% when 'local' %}
          Hi {{ customer.first_name }}, we're getting your order ready for delivery. By placing an order, the buyer acknowledges that they have read, understood, and agreed
to this Shipping & Live Arrival Guarantee policy in full. We ship Monday through Wednesday.
        {% else %}
          We're getting your order ready to be shipped. We will notify you when it has been sent. By placing an order, the buyer acknowledges that they have read, understood, and agreed
to this Shipping & Live Arrival Guarantee policy in full.
      {% endcase %}
      {% if delivery_instructions != blank %}
        <p><b>Delivery information:</b> {{ delivery_instructions }}</p>
      {% endif %}
    {% endif %}
  {% endif %}
  {% assign gift_card_line_items = line_items | where: "gift_card" %}
  {% assign found_gift_card_with_recipient_email = false %}
  {% for line_item in gift_card_line_items %}
    {% if line_item.properties["__shopify_send_gift_card_to_recipient"] and line_item.properties["Recipient email"] %}
      {% assign found_gift_card_with_recipient_email = true %}
      {% break %}
    {% endif %}
  {% endfor %}
  {% if found_gift_card_with_recipient_email %}
    <p>Your gift card recipient will receive an email with their gift card code.</p>
  {% elsif gift_card_line_items.first %}
    <p>You'll receive separate emails for any gift cards.</p>
  {% endif %}
{% endcapture %}

