{% comment %}
  SSA Shipping Weather Forecast (snippet version)
  Renders inside the product section as a block (or directly via {% render %}).
  Filters by product.type - default: Shrimp, Crayfish, Snails, Crab.

  Behavior:
    - User enters destination ZIP (persisted in localStorage)
    - Fetches 14-day forecast via pack-slip.fly.dev/api/weather
    - Shows 3 delivery day cards only (ship day excluded — destination weather
      that day is irrelevant since the package doesn't arrive until the next day)
    - Status and pack recommendations based on delivery days only

  Usage as a block in main-product.liquid:
    {%- when 'shipping_weather' -%}
      {% render 'ssa-shipping-weather', block: block %}

  Usage as a direct render (no block):
    {% render 'ssa-shipping-weather' %}
{% endcomment %}

{%- liquid
  if block
    assign livestock_types_raw = block.settings.livestock_types | default: 'Shrimp,Crayfish,Snails,Crab'
  else
    assign livestock_types_raw = 'Shrimp,Crayfish,Snails,Crab'
  endif
  assign livestock_types = livestock_types_raw | downcase | split: ','
  assign current_type = product.type | default: '' | downcase | strip
  assign is_livestock = false
  for t in livestock_types
    assign t_clean = t | strip
    if t_clean == current_type
      assign is_livestock = true
      break
    endif
  endfor
-%}

{%- if is_livestock -%}

<div class="ssa-weather" data-ssa-weather>
  <div class="ssa-weather__header">
    <h3 class="ssa-weather__title">Shipping Weather Check</h3>
    <p class="ssa-weather__sub">Enter your ZIP for a 14-day forecast at your delivery address. We ship Tuesdays (orders by 1 PM) and Wednesdays (dry goods + 2-day or overnight only). Live shrimp and aquatic livestock are sensitive to temperature extremes during transit.</p>
  </div>

  <form class="ssa-weather__form" data-ssa-weather-form>
    <label class="ssa-weather__label" for="ssa-weather-zip">Destination ZIP code</label>
    <div class="ssa-weather__input-row">
      <input
        type="text"
        id="ssa-weather-zip"
        name="zip"
        inputmode="numeric"
        pattern="[0-9]{5}"
        maxlength="5"
        placeholder="55802"
        autocomplete="postal-code"
        class="ssa-weather__input"
        required
      >
      <button type="submit" class="ssa-weather__submit">Check Forecast</button>
    </div>
    <p class="ssa-weather__error" data-ssa-weather-error hidden></p>
  </form>

  <div class="ssa-weather__loading" data-ssa-weather-loading hidden>
    <span class="ssa-weather__spinner" aria-hidden="true"></span>
    <span>Loading forecast...</span>
  </div>

  <div class="ssa-weather__results" data-ssa-weather-results hidden>
    <div class="ssa-weather__meta">
      <span class="ssa-weather__location" data-ssa-weather-location></span>
      <button type="button" class="ssa-weather__change" data-ssa-weather-change>Change ZIP</button>
    </div>

    <div class="ssa-weather__shipping-week" data-ssa-weather-shipping-week></div>

    <div class="ssa-weather__pack-rec" data-ssa-weather-pack hidden></div>

    <details class="ssa-weather__details">
      <summary class="ssa-weather__details-summary">View 14-day forecast</summary>
      <div class="ssa-weather__legend">
        <span class="ssa-weather__legend-item"><span class="ssa-weather__dot ssa-weather__dot--safe"></span> Safe</span>
        <span class="ssa-weather__legend-item"><span class="ssa-weather__dot ssa-weather__dot--caution"></span> Caution</span>
        <span class="ssa-weather__legend-item"><span class="ssa-weather__dot ssa-weather__dot--risk"></span> High risk</span>
        <span class="ssa-weather__legend-item"><span class="ssa-weather__dot ssa-weather__dot--transit"></span> Transit window</span>
      </div>
      <div class="ssa-weather__grid" data-ssa-weather-grid></div>
    </details>

    <p class="ssa-weather__disclaimer" data-ssa-weather-disclaimer>
      Forecast data from Open-Meteo. Thresholds reflect typical livestock tolerances and are guidance only. We check conditions on both ends before every shipment and will reach out if a delay is warranted.
    </p>
  </div>
</div>

<style>
  .ssa-weather *, .ssa-weather *::before, .ssa-weather *::after { box-sizing: border-box; }

  .ssa-weather {
    font-family: 'DM Sans', system-ui, sans-serif !important;
    color: #1e1a1a !important;
    line-height: 1.55 !important;
    -webkit-font-smoothing: antialiased;
    max-width: var(--page-width, 1200px) !important;
    margin: 0.5rem auto !important;
    padding: 1rem !important;
    background: #fdfaf6 !important;
    border: 1px solid #e8e2da !important;
    border-radius: 10px !important;
  }

  .ssa-weather__header { margin-bottom: 1rem !important; }

  .ssa-weather__title {
    font-family: 'Playfair Display', Georgia, serif !important;
    font-size: 1.35rem !important;
    font-weight: 600 !important;
    color: #111111 !important;
    margin: 0 0 0.35rem !important;
    padding: 0 !important;
    line-height: 1.2 !important;
    letter-spacing: -0.01em !important;
  }

  .ssa-weather__sub {
    font-size: 0.82rem !important;
    color: #6b6060 !important;
    font-weight: 300 !important;
    line-height: 1.6 !important;
    margin: 0 !important;
  }

  .ssa-weather__label {
    display: block !important;
    font-family: 'DM Sans', sans-serif !important;
    font-size: 0.75rem !important;
    font-weight: 500 !important;
    text-transform: uppercase !important;
    letter-spacing: 0.12em !important;
    color: #6b6060 !important;
    margin-bottom: 0.6rem !important;
  }

  .ssa-weather__input-row {
    display: flex !important;
    gap: 0.625rem !important;
    max-width: 440px !important;
  }

  .ssa-weather__input {
    flex: 1 !important;
    padding: 0.6rem 0.85rem !important;
    font-family: 'DM Sans', sans-serif !important;
    font-size: 0.9rem !important;
    color: #1e1a1a !important;
    background: #fff !important;
    border: 1px solid #e8e2da !important;
    border-radius: 8px !important;
    transition: border-color 0.15s ease, box-shadow 0.15s ease !important;
  }

  .ssa-weather__input:focus {
    outline: none !important;
    border-color: #F40909 !important;
    box-shadow: 0 0 0 3px rgba(244, 9, 9, 0.08) !important;
  }

  .ssa-weather__submit {
    padding: 0.6rem 1.2rem !important;
    font-family: 'DM Sans', sans-serif !important;
    font-size: 0.875rem !important;
    font-weight: 500 !important;
    color: #fff !important;
    background: #F40909 !important;
    border: none !important;
    border-radius: 8px !important;
    cursor: pointer !important;
    white-space: nowrap !important;
    transition: background 0.15s ease, transform 0.15s ease !important;
  }

  .ssa-weather__submit:hover { background: #b50707 !important; }
  .ssa-weather__submit:active { transform: translateY(1px) !important; }
  .ssa-weather__submit:disabled { background: #c4baba !important; cursor: not-allowed !important; }

  .ssa-weather__error {
    color: #F40909 !important;
    font-size: 0.9rem !important;
    margin: 0.75rem 0 0 !important;
  }

  .ssa-weather__results { margin-top: 1rem !important; }

  .ssa-weather__meta {
    display: flex !important;
    justify-content: space-between !important;
    align-items: baseline !important;
    margin-bottom: 0.75rem !important;
    padding-bottom: 0.55rem !important;
    border-bottom: 1px solid #e8e2da !important;
    flex-wrap: wrap !important;
    gap: 0.5rem !important;
  }

  .ssa-weather__location {
    font-family: 'Playfair Display', Georgia, serif !important;
    font-weight: 600 !important;
    color: #111111 !important;
    font-size: 1rem !important;
  }

  .ssa-weather__change {
    background: none !important;
    border: none !important;
    color: #b50707 !important;
    font-family: 'DM Sans', sans-serif !important;
    font-size: 0.85rem !important;
    font-weight: 500 !important;
    cursor: pointer !important;
    padding: 0 !important;
    text-decoration: underline !important;
    text-underline-offset: 3px !important;
  }

  .ssa-weather__change:hover { color: #F40909 !important; }

  /* Single heading inside the shipping week callout */
  .ssa-weather__shipping-week-status {
    display: flex !important;
    align-items: center !important;
    gap: 0.4rem !important;
    margin: 0 0 0.5rem !important;
    font-family: 'Playfair Display', Georgia, serif !important;
    font-size: 1.05rem !important;
    font-weight: 600 !important;
    color: #111111 !important;
    line-height: 1.3 !important;
  }

  .ssa-weather__shipping-week--safe    .ssa-weather__shipping-week-status { color: #2e7d32 !important; }
  .ssa-weather__shipping-week--caution .ssa-weather__shipping-week-status { color: #c98a1a !important; }
  .ssa-weather__shipping-week--risk    .ssa-weather__shipping-week-status { color: #F40909 !important; }

  /* Holiday note below heading */
  .ssa-weather__shipping-week-holiday {
    font-family: 'DM Sans', sans-serif !important;
    font-size: 0.85rem !important;
    font-weight: 400 !important;
    color: #6b6060 !important;
    margin: -0.25rem 0 0.75rem !important;
    line-height: 1.5 !important;
  }

  /* Shipping week callout */
  .ssa-weather__shipping-week {
    background: #fff !important;
    border: 1px solid #e8e2da !important;
    border-left: 4px solid #2e7d32 !important;
    border-radius: 10px !important;
    padding: 0.85rem 1rem !important;
    margin-bottom: 0.85rem !important;
  }

  .ssa-weather__shipping-week--caution { border-left-color: #c98a1a !important; }
  .ssa-weather__shipping-week--risk    { border-left-color: #F40909 !important; }

  .ssa-weather__shipping-week-label {
    font-family: 'DM Sans', sans-serif !important;
    font-size: 0.7rem !important;
    font-weight: 500 !important;
    text-transform: uppercase !important;
    letter-spacing: 0.14em !important;
    color: #6b6060 !important;
    margin: 0 0 0.6rem !important;
  }

  .ssa-weather__shipping-week-title {
    font-family: 'Playfair Display', Georgia, serif !important;
    font-size: 1.25rem !important;
    font-weight: 600 !important;
    color: #111111 !important;
    margin: 0 0 0.6rem !important;
    line-height: 1.3 !important;
  }

  .ssa-weather__shipping-week-body {
    font-size: 0.85rem !important;
    color: #1e1a1a !important;
    font-weight: 300 !important;
    line-height: 1.55 !important;
    margin: 0 0 0.5rem !important;
  }

  /* KARE-style delivery day cards — 3 equal columns */
  .ssa-weather__shipping-week-temps {
    display: grid !important;
    grid-template-columns: repeat(3, 1fr) !important;
    gap: 0.5rem !important;
    margin-top: 0.6rem !important;
  }

  .ssa-weather__transit-day {
    background: #fff !important;
    border: 1px solid #e8e2da !important;
    border-radius: 10px !important;
    overflow: hidden !important;
    display: flex !important;
    flex-direction: column !important;
    min-height: 150px !important;
  }

  /* Amber glow — hot caution days */
  .ssa-weather__transit-day--caution {
    border-color: #e8960a !important;
    box-shadow: 0 0 0 1px #e8960a, 0 0 8px 3px rgba(232, 150, 10, 0.45) !important;
  }

  /* Blue glow — cold caution days */
  .ssa-weather__transit-day--caution.ssa-weather__transit-day--cold {
    border-color: #5b8ec4 !important;
    box-shadow: 0 0 0 1px #5b8ec4, 0 0 8px 3px rgba(91, 142, 196, 0.5) !important;
  }

  /* Animated fire glow — hot risk days */
  @keyframes ssa-fire {
    0%   { box-shadow: 0 0 0 1px #ff4500, 0 0 7px 3px rgba(255, 69, 0, 0.7),  0 0 14px 5px rgba(255, 140, 0, 0.3); }
    40%  { box-shadow: 0 0 0 1px #ff0000, 0 0 9px 4px rgba(255, 0, 0, 0.8),   0 0 18px 7px rgba(255, 60, 0, 0.35); }
    70%  { box-shadow: 0 0 0 1px #ff6600, 0 0 8px 4px rgba(255, 100, 0, 0.65),0 0 16px 6px rgba(255, 165, 0, 0.25); }
    100% { box-shadow: 0 0 0 1px #ff4500, 0 0 7px 3px rgba(255, 69, 0, 0.7),  0 0 14px 5px rgba(255, 140, 0, 0.3); }
  }

  .ssa-weather__transit-day--risk {
    border-color: #ff4500 !important;
    animation: ssa-fire 1.1s ease-in-out infinite !important;
  }

  /* Animated freeze glow — cold risk days */
  @keyframes ssa-freeze {
    0%   { box-shadow: 0 0 0 1px #1e6fbf, 0 0 7px 3px rgba(30, 111, 191, 0.7),  0 0 14px 5px rgba(100, 180, 255, 0.3); }
    40%  { box-shadow: 0 0 0 1px #0a4d9e, 0 0 9px 4px rgba(10, 77, 158, 0.8),   0 0 18px 7px rgba(30, 111, 191, 0.35); }
    70%  { box-shadow: 0 0 0 1px #5b8ec4, 0 0 8px 4px rgba(91, 142, 196, 0.65), 0 0 16px 6px rgba(160, 210, 255, 0.25); }
    100% { box-shadow: 0 0 0 1px #1e6fbf, 0 0 7px 3px rgba(30, 111, 191, 0.7),  0 0 14px 5px rgba(100, 180, 255, 0.3); }
  }

  .ssa-weather__transit-day--risk.ssa-weather__transit-day--cold {
    border-color: #1e6fbf !important;
    animation: ssa-freeze 1.1s ease-in-out infinite !important;
  }

  .ssa-weather__transit-day-body {
    flex: 1 !important;
    display: flex !important;
    flex-direction: column !important;
    align-items: center !important;
    justify-content: center !important;
    padding: 0.7rem 0.5rem 0.6rem !important;
    gap: 0.2rem !important;
    text-align: center !important;
  }

  .ssa-weather__transit-day-temps {
    font-family: 'Playfair Display', Georgia, serif !important;
    font-size: 1.25rem !important;
    font-weight: 700 !important;
    color: #111111 !important;
    line-height: 1.1 !important;
  }

  .ssa-weather__transit-day-condition {
    font-family: 'DM Sans', sans-serif !important;
    font-size: 0.68rem !important;
    font-weight: 700 !important;
    text-transform: uppercase !important;
    letter-spacing: 0.1em !important;
    color: #2e7d32 !important;
    line-height: 1.2 !important;
  }

  /* Condition label colors */
  .ssa-weather__transit-day--safe    .ssa-weather__transit-day-condition { color: #6b7280 !important; }
  .ssa-weather__transit-day--caution .ssa-weather__transit-day-condition { color: #c98a1a !important; }
  .ssa-weather__transit-day--risk    .ssa-weather__transit-day-condition { color: #F40909 !important; }
  .ssa-weather__transit-day--risk.ssa-weather__transit-day--cold .ssa-weather__transit-day-condition { color: #1e6fbf !important; }

  /* Footer colors — safe=neutral, caution=amber (both warm+cold), cold risk=blue */
  .ssa-weather__transit-day--safe    .ssa-weather__transit-day-footer    { background: #6b7280 !important; }
  .ssa-weather__transit-day--caution .ssa-weather__transit-day-footer    { background: #c98a1a !important; }
  .ssa-weather__transit-day--cold    .ssa-weather__transit-day-footer    { background: #1e6fbf !important; }
  .ssa-weather__transit-day--caution.ssa-weather__transit-day--cold .ssa-weather__transit-day-footer { background: #c98a1a !important; }

  /* 14-day grid footer colors */
  .ssa-weather__day--safe    .ssa-weather__day-footer { background: #6b7280 !important; }
  .ssa-weather__day--caution .ssa-weather__day-footer { background: #c98a1a !important; }
  .ssa-weather__day--cold    .ssa-weather__day-footer { background: #1e6fbf !important; }
  .ssa-weather__day--caution.ssa-weather__day--cold .ssa-weather__day-footer { background: #c98a1a !important; }

  .ssa-weather__transit-day-icon {
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
    margin: 0.35rem 0 !important;
  }

  @keyframes ssa-icon-pulse-caution {
    0%, 100% { transform: scale(1); }
    50%       { transform: scale(1.14); }
  }

  @keyframes ssa-icon-pulse-risk {
    0%, 100% { transform: scale(1); }
    30%      { transform: scale(1.22); }
    70%      { transform: scale(0.93); }
  }

  .ssa-weather__transit-day--caution .ssa-weather__transit-day-icon { animation: ssa-icon-pulse-caution 2s ease-in-out infinite !important; }
  .ssa-weather__transit-day--risk    .ssa-weather__transit-day-icon { animation: ssa-icon-pulse-risk 0.95s ease-in-out infinite !important; }

  /* Red store-color footer */
  .ssa-weather__transit-day-footer {
    background: #F40909 !important;
    color: #fff !important;
    padding: 0.4rem 0.4rem 0.5rem !important;
    text-align: center !important;
  }

  .ssa-weather__transit-day-dow {
    display: block !important;
    font-family: 'DM Sans', sans-serif !important;
    font-size: 0.72rem !important;
    font-weight: 600 !important;
    text-transform: uppercase !important;
    letter-spacing: 0.12em !important;
  }

  .ssa-weather__transit-day-num {
    display: block !important;
    font-family: 'Playfair Display', Georgia, serif !important;
    font-size: 1.35rem !important;
    font-weight: 700 !important;
    line-height: 1 !important;
    margin: 0.05rem 0 !important;
  }

  .ssa-weather__transit-day-role {
    display: block !important;
    font-family: 'DM Sans', sans-serif !important;
    font-size: 0.6rem !important;
    font-weight: 500 !important;
    text-transform: uppercase !important;
    letter-spacing: 0.08em !important;
    opacity: 0.88 !important;
  }

  /* Pack recommendation */
  .ssa-weather__pack-rec {
    background: #fff8f0 !important;
    border: 1px solid #e8e2da !important;
    border-left: 4px solid #F40909 !important;
    border-radius: 10px !important;
    padding: 0.85rem 1rem !important;
    margin-bottom: 0.85rem !important;
  }

  .ssa-weather__pack-rec--triggered-cold { border-left-color: #1e6fbf !important; background: #f4f8fc !important; }

  .ssa-weather__pack-label {
    font-family: 'DM Sans', sans-serif !important;
    font-size: 0.7rem !important;
    font-weight: 500 !important;
    text-transform: uppercase !important;
    letter-spacing: 0.14em !important;
    color: #6b6060 !important;
    margin: 0 0 0.3rem !important;
  }

  .ssa-weather__pack-title {
    font-family: 'Playfair Display', Georgia, serif !important;
    font-size: 1rem !important;
    font-weight: 600 !important;
    color: #111111 !important;
    margin: 0 0 0.3rem !important;
    line-height: 1.3 !important;
  }

  .ssa-weather__pack-body {
    font-size: 0.85rem !important;
    color: #1e1a1a !important;
    font-weight: 300 !important;
    line-height: 1.55 !important;
    margin: 0 0 0.5rem !important;
  }

  .ssa-weather__pack-options {
    display: flex !important;
    gap: 0.5rem !important;
    flex-wrap: wrap !important;
  }

  .ssa-weather__pack-btn {
    display: inline-flex !important;
    align-items: center !important;
    padding: 0.5rem 1rem !important;
    background: #F40909 !important;
    color: #fff !important;
    font-family: 'DM Sans', sans-serif !important;
    font-size: 0.82rem !important;
    font-weight: 500 !important;
    text-decoration: none !important;
    border-radius: 8px !important;
    transition: background 0.15s ease, transform 0.15s ease !important;
  }

  .ssa-weather__pack-btn:hover  { background: #b50707 !important; color: #fff !important; }
  .ssa-weather__pack-btn:active { transform: translateY(1px) !important; }

  .ssa-weather__pack-note {
    font-size: 0.78rem !important;
    color: #6b6060 !important;
    margin: 0.6rem 0 0 !important;
    line-height: 1.5 !important;
    font-style: italic !important;
  }

  /* 14-day forecast */
  .ssa-weather__details { margin-bottom: 0.75rem !important; }

  .ssa-weather__details-summary {
    cursor: pointer !important;
    font-family: 'DM Sans', sans-serif !important;
    font-size: 0.9rem !important;
    font-weight: 500 !important;
    color: #1e1a1a !important;
    padding: 0.6rem 0 !important;
    list-style: none !important;
    user-select: none !important;
  }

  .ssa-weather__details-summary::-webkit-details-marker { display: none !important; }
  .ssa-weather__details-summary::before { content: '+' !important; display: inline-block !important; width: 1.25em !important; color: #F40909 !important; font-weight: 700 !important; font-size: 1.1em !important; }
  .ssa-weather__details[open] .ssa-weather__details-summary::before { content: '\2013' !important; }

  .ssa-weather__legend {
    display: flex !important;
    gap: 1rem !important;
    margin: 0.6rem 0 0.75rem !important;
    font-size: 0.75rem !important;
    color: #6b6060 !important;
    flex-wrap: wrap !important;
  }

  .ssa-weather__legend-item { display: inline-flex !important; align-items: center !important; gap: 0.4rem !important; }

  .ssa-weather__dot { display: inline-block !important; width: 10px !important; height: 10px !important; border-radius: 50% !important; }
  .ssa-weather__dot--safe    { background: #6b7280 !important; }
  .ssa-weather__dot--caution { background: #c98a1a !important; }
  .ssa-weather__dot--risk    { background: #F40909 !important; }
  .ssa-weather__dot--transit { background: transparent !important; border: 2px solid #111111 !important; }

  .ssa-weather__grid {
    display: grid !important;
    grid-template-columns: repeat(7, 1fr) !important;
    gap: 0.5rem !important;
  }

  /* Mini KARE-style 14-day grid cards */
  .ssa-weather__day {
    background: #fff !important;
    border: 1px solid #e8e2da !important;
    border-radius: 10px !important;
    overflow: hidden !important;
    display: flex !important;
    flex-direction: column !important;
  }

  .ssa-weather__day--transit { outline: 2px solid #111111 !important; outline-offset: 1px !important; }

  .ssa-weather__day--caution {
    border-color: #e8960a !important;
    box-shadow: 0 0 0 1px #e8960a, 0 0 6px 2px rgba(232, 150, 10, 0.4) !important;
  }

  .ssa-weather__day--caution.ssa-weather__day--cold {
    border-color: #5b8ec4 !important;
    box-shadow: 0 0 0 1px #5b8ec4, 0 0 6px 2px rgba(91, 142, 196, 0.45) !important;
  }

  .ssa-weather__day--risk {
    border-color: #ff4500 !important;
    animation: ssa-fire 1.1s ease-in-out infinite !important;
  }

  .ssa-weather__day--risk.ssa-weather__day--cold {
    border-color: #1e6fbf !important;
    animation: ssa-freeze 1.1s ease-in-out infinite !important;
  }

  .ssa-weather__day-body {
    flex: 1 !important;
    padding: 0.55rem 0.4rem 0.45rem !important;
    text-align: center !important;
    display: flex !important;
    flex-direction: column !important;
    align-items: center !important;
    gap: 0.15rem !important;
  }

  .ssa-weather__day-name  { font-family: 'DM Sans', sans-serif !important; font-weight: 600 !important; color: #6b6060 !important; text-transform: uppercase !important; font-size: 0.6rem !important; letter-spacing: 0.08em !important; }
  .ssa-weather__day-high  { font-family: 'Playfair Display', Georgia, serif !important; font-weight: 700 !important; color: #111111 !important; font-size: 1rem !important; line-height: 1.1 !important; }
  .ssa-weather__day-low   { color: #6b6060 !important; font-size: 0.72rem !important; }

  .ssa-weather__day-footer {
    background: #F40909 !important;
    color: #fff !important;
    text-align: center !important;
    padding: 0.3rem 0.2rem 0.35rem !important;
    border-radius: 0 0 9px 9px !important;
    font-family: 'Playfair Display', Georgia, serif !important;
    font-weight: 700 !important;
    font-size: 0.85rem !important;
    line-height: 1 !important;
  }

  .ssa-weather__disclaimer {
    font-size: 0.75rem !important;
    color: #6b6060 !important;
    margin: 0.75rem 0 0 !important;
    line-height: 1.6 !important;
  }

  .ssa-weather__loading {
    display: flex !important;
    align-items: center !important;
    gap: 0.7rem !important;
    margin-top: 1rem !important;
    color: #6b6060 !important;
    font-size: 0.95rem !important;
  }

  .ssa-weather__loading[hidden],
  .ssa-weather [hidden] { display: none !important; }

  .ssa-weather__spinner {
    width: 16px !important;
    height: 16px !important;
    border: 2px solid #e8e2da !important;
    border-top-color: #F40909 !important;
    border-radius: 50% !important;
    animation: ssa-weather-spin 0.7s linear infinite !important;
  }

  @keyframes ssa-weather-spin { to { transform: rotate(360deg); } }

  @media (max-width: 640px) {
    .ssa-weather { padding: 0.85rem !important; margin: 0.5rem auto !important; }
    .ssa-weather__title { font-size: 1.2rem !important; }
    .ssa-weather__grid { grid-template-columns: repeat(4, 1fr) !important; }
    .ssa-weather__input-row { flex-direction: column !important; }
    .ssa-weather__input-row .ssa-weather__submit { width: 100% !important; }
    .ssa-weather__shipping-week-temps { grid-template-columns: repeat(3, 1fr) !important; }
    .ssa-weather__pack-options { flex-direction: column !important; }
    .ssa-weather__pack-btn { justify-content: center !important; }
  }
</style>

<script>
(function() {
  var root = document.querySelector('[data-ssa-weather]');
  if (!root) return;

  var form           = root.querySelector('[data-ssa-weather-form]');
  var input          = root.querySelector('#ssa-weather-zip');
  var errorEl        = root.querySelector('[data-ssa-weather-error]');
  var resultsEl      = root.querySelector('[data-ssa-weather-results]');
  var loadingEl      = root.querySelector('[data-ssa-weather-loading]');
  var gridEl         = root.querySelector('[data-ssa-weather-grid]');
  var shippingWeekEl = root.querySelector('[data-ssa-weather-shipping-week]');
  var packEl         = root.querySelector('[data-ssa-weather-pack]');
  var locationEl     = root.querySelector('[data-ssa-weather-location]');
  var changeBtn      = root.querySelector('[data-ssa-weather-change]');
  var disclaimerEl   = root.querySelector('[data-ssa-weather-disclaimer]');

  var WEATHER_API   = 'https://pack-slip.fly.dev/api/weather';
  var HEAT_PACK_URL = '/products/heat-pack';
  var ICE_PACK_URL  = '/products/ice-pack';
  var STORAGE_KEY   = 'ssa_shipping_zip';

  function showError(msg) { errorEl.textContent = msg; errorEl.hidden = false; }
  function clearError()   { errorEl.textContent = ''; errorEl.hidden = true; }
  function setLoading(on) { loadingEl.hidden = !on; }

  function worstClassification(days) {
    var worst = 'safe';
    for (var i = 0; i < days.length; i++) {
      if (days[i].classification === 'risk') return 'risk';
      if (days[i].classification === 'caution') worst = 'caution';
    }
    return worst;
  }

  // Inline SVG icons — no external dependencies
  function svgSun(color) {
    return '<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="' + color + '" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">' +
      '<circle cx="12" cy="12" r="4"/>' +
      '<path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"/>' +
      '</svg>';
  }

  function svgThermometer(color) {
    return '<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="' + color + '" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">' +
      '<path d="M14 14.76V3.5a2.5 2.5 0 0 0-5 0v11.26a4.5 4.5 0 1 0 5 0z"/>' +
      '</svg>';
  }

  function svgSnowflake(color) {
    return '<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="' + color + '" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">' +
      '<line x1="12" y1="2" x2="12" y2="22"/>' +
      '<line x1="2" y1="12" x2="22" y2="12"/>' +
      '<line x1="4.93" y1="4.93" x2="19.07" y2="19.07"/>' +
      '<line x1="19.07" y1="4.93" x2="4.93" y2="19.07"/>' +
      '<polyline points="8 2 12 6 16 2"/>' +
      '<polyline points="8 22 12 18 16 22"/>' +
      '<polyline points="2 8 6 12 2 16"/>' +
      '<polyline points="22 8 18 12 22 16"/>' +
      '</svg>';
  }

  function svgStatusIcon(worst) {
    if (worst === 'risk')    return '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>';
    if (worst === 'caution') return '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>';
    return '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>';
  }

  function conditionIcon(classification, high, low) {
    if (classification === 'risk')    return high >= 85 ? svgThermometer('#F40909') : svgSnowflake('#1e6fbf');
    if (classification === 'caution') return high >= 75 ? svgThermometer('#c98a1a') : svgSnowflake('#5b8ec4');
    return svgSun('#2e7d32');
  }

  function conditionLabel(classification, high, low) {
    if (classification === 'risk')    return high >= 85 ? 'Too Hot' : 'Too Cold';
    if (classification === 'caution') return high >= 75 ? 'Very Warm' : 'Cool';
    return 'Good';
  }

  function formatDate(dateStr) {
    var d = new Date(dateStr + 'T12:00:00');
    return {
      day:      d.toLocaleDateString('en-US', { weekday: 'short' }).toUpperCase(),
      dayFull:  d.toLocaleDateString('en-US', { weekday: 'long' }),
      date:     d.toLocaleDateString('en-US', { month: 'numeric', day: 'numeric' }),
      dateNum:  d.getDate(),
      monthDay: d.toLocaleDateString('en-US', { month: 'long', day: 'numeric' }),
      month:    d.toLocaleDateString('en-US', { month: 'short' }).toUpperCase()
    };
  }

  function fetchWithTimeout(url, ms) {
    ms = ms || 10000;
    return new Promise(function(resolve, reject) {
      var timedOut = false;
      var timer = setTimeout(function() {
        timedOut = true;
        reject(new Error('Request timed out. Please check your connection and try again.'));
      }, ms);
      fetch(url).then(function(res) {
        if (timedOut) return;
        clearTimeout(timer);
        resolve(res);
      }).catch(function(err) {
        if (timedOut) return;
        clearTimeout(timer);
        reject(err);
      });
    });
  }

  function fetchWeather(zip) {
    return fetchWithTimeout(WEATHER_API + '?zip=' + encodeURIComponent(zip))
      .then(function(res) {
        if (!res.ok) {
          return res.json().then(function(d) {
            throw new Error(d.error || 'Weather service unavailable. Please try again.');
          });
        }
        return res.json();
      });
  }

  function renderShippingWeek(shipDate, deliveryDays, shipNote, shipRestriction, thresholds) {
    thresholds = thresholds || { dontShipAbove: 90, icePackAbove: 80 };
    var worst = worstClassification(deliveryDays);

    var shipDesc = shipNote
      ? 'Holiday · Ships ' + shipDate.dayFull + ', ' + shipDate.monthDay
      : 'Ships ' + shipDate.dayFull + ', ' + shipDate.monthDay;
    var heading = {
      safe:    'Safe to Ship — ' + shipDesc,
      caution: 'Borderline Conditions — ' + shipDesc,
      risk:    'High Risk — ' + shipDesc
    }[worst];

    var body;
    if (worst === 'safe') {
      body = 'Transit-window temperatures look safe for livestock shipping.';
    } else if (worst === 'caution') {
      body = 'Some delivery days have elevated temperatures. We\'ll monitor conditions and reach out if any concerns arise before shipping.';
    } else {
      body = 'Forecast shows temperature extremes during transit. We\'ll reach out before shipping and may recommend delaying to a better window.';
    }

    var daysHtml = '';
    for (var j = 0; j < deliveryDays.length; j++) {
      var d = deliveryDays[j];
      var icon  = conditionIcon(d.classification, d.high, d.low);
      var label = conditionLabel(d.classification, d.high, d.low);
      var isCold = d.classification !== 'safe' && d.high < (d.classification === 'risk' ? thresholds.dontShipAbove : thresholds.icePackAbove);
      var coldClass = isCold ? ' ssa-weather__transit-day--cold' : '';
      daysHtml +=
        '<div class="ssa-weather__transit-day ssa-weather__transit-day--' + d.classification + coldClass + '">' +
          '<div class="ssa-weather__transit-day-body">' +
            '<div class="ssa-weather__transit-day-temps">' + d.high + '°</div>' +
            '<div class="ssa-weather__transit-day-condition">' + label + '</div>' +
            '<div class="ssa-weather__transit-day-icon">' + icon + '</div>' +
          '</div>' +
          '<div class="ssa-weather__transit-day-footer">' +
            '<span class="ssa-weather__transit-day-dow">' + d.dayShort + '</span>' +
            '<span class="ssa-weather__transit-day-num">' + d.dateNum + '</span>' +
            '<span class="ssa-weather__transit-day-role">Delivery</span>' +
          '</div>' +
        '</div>';
    }

    shippingWeekEl.className = 'ssa-weather__shipping-week ssa-weather__shipping-week--' + worst;
    shippingWeekEl.innerHTML =
      '<div class="ssa-weather__shipping-week-status">' + svgStatusIcon(worst) + ' ' + heading + '</div>' +
      (shipNote        ? '<p class="ssa-weather__shipping-week-holiday">' + shipNote        + '</p>' : '') +
      (shipRestriction ? '<p class="ssa-weather__shipping-week-holiday">' + shipRestriction + '</p>' : '') +
      '<p class="ssa-weather__shipping-week-body">' + body + '</p>' +
      '<div class="ssa-weather__shipping-week-temps">' + daysHtml + '</div>';
  }

  function renderPackRecommendation(deliveryDays) {
    var sumLow = 0, sumHigh = 0;
    for (var i = 0; i < deliveryDays.length; i++) {
      sumLow  += deliveryDays[i].low;
      sumHigh += deliveryDays[i].high;
    }
    var avgLow  = Math.round(sumLow  / deliveryDays.length);
    var avgHigh = Math.round(sumHigh / deliveryDays.length);

    var needsHeat = avgLow  <= 32;
    var needsCold = avgHigh >  80;

    if (!needsHeat && !needsCold) { packEl.hidden = true; packEl.innerHTML = ''; return; }

    var minLow = Infinity, maxHigh = -Infinity;
    for (var j = 0; j < deliveryDays.length; j++) {
      if (deliveryDays[j].low  < minLow)  minLow  = deliveryDays[j].low;
      if (deliveryDays[j].high > maxHigh) maxHigh = deliveryDays[j].high;
    }

    var label, title, body, modClass, note, buttonsHtml;

    if (needsHeat && needsCold) {
      modClass    = 'ssa-weather__pack-rec--triggered-both';
      label       = 'Recommended add-ons';
      title       = 'Add both packs for this shipping window';
      body        = 'Average daytime high is ' + avgHigh + '°F and average overnight low is ' + avgLow + '°F across your delivery window. Adding both lets us deploy the right one at packing time based on conditions that morning.';
      note        = 'Heat packs run 72 hours and cover the full transit window. Ice packs run 48 hours and are most effective for early-week deliveries.';
      buttonsHtml = '<a href="' + HEAT_PACK_URL + '" class="ssa-weather__pack-btn">72-Hour Heat Pack</a>' +
                    '<a href="' + ICE_PACK_URL  + '" class="ssa-weather__pack-btn">48-Hour Ice Pack</a>';
    } else if (needsHeat) {
      modClass    = 'ssa-weather__pack-rec--triggered-cold';
      label       = 'Recommended add-on';
      title       = 'Add a heat pack for freezing transit';
      body        = 'Average overnight low across your delivery window is ' + avgLow + '°F (bottoming out at ' + minLow + '°F). A 72-hour heat pack is essential for shipments averaging at or below freezing.';
      note        = 'Heat packs activate on contact with air and run for approximately 72 hours, covering the entire transit window.';
      buttonsHtml = '<a href="' + HEAT_PACK_URL + '" class="ssa-weather__pack-btn">72-Hour Heat Pack</a>';
    } else {
      modClass    = 'ssa-weather__pack-rec--triggered-heat';
      label       = 'Recommended add-on';
      title       = 'Add an ice pack for warm transit';
      body        = 'Average daytime high across your delivery window is ' + avgHigh + '°F (peaking at ' + maxHigh + '°F). An ice pack helps prevent heat stress while the box is most exposed to ambient temperatures.';
      note        = 'Ice packs run approximately 48 hours and are most effective for early-week deliveries.';
      buttonsHtml = '<a href="' + ICE_PACK_URL + '" class="ssa-weather__pack-btn">48-Hour Ice Pack</a>';
    }

    packEl.hidden    = false;
    packEl.className = 'ssa-weather__pack-rec ' + modClass;
    packEl.innerHTML =
      '<p class="ssa-weather__pack-label">'  + label + '</p>' +
      '<h4 class="ssa-weather__pack-title">' + title + '</h4>' +
      '<p class="ssa-weather__pack-body">'   + body  + '</p>' +
      '<div class="ssa-weather__pack-options">' + buttonsHtml + '</div>' +
      '<p class="ssa-weather__pack-note">'   + note  + '</p>';
  }

  function renderForecast(data) {
    locationEl.textContent = data.location || input.value.trim();
    gridEl.innerHTML = '';

    // Build all transit days, then split ship day from delivery days
    var allTransit = (data.transitWindow || []).map(function(d) {
      var fmt = formatDate(d.date);
      return {
        dateStr:        d.date,
        high:           Math.round(d.high),
        low:            Math.round(d.low),
        classification: d.classification,
        dayShort:       fmt.day,
        dayFull:        fmt.dayFull,
        dateNum:        fmt.dateNum,
        monthDay:       fmt.monthDay
      };
    });

    var shipDateObj  = allTransit.length ? allTransit[0] : null;
    var deliveryDays = allTransit.slice(1); // delivery days only — ship day excluded from display

    var thresholds = data.thresholds || { dontShipAbove: 90, icePackAbove: 80 };

    var transitDateSet = {};
    allTransit.forEach(function(d) { transitDateSet[d.dateStr] = true; });

    (data.forecast || []).forEach(function(d) {
      var high      = Math.round(d.high);
      var low       = Math.round(d.low);
      var fmt       = formatDate(d.date);
      var isTransit = !!transitDateSet[d.date];

      var isColdDay = d.classification !== 'safe' && high < (d.classification === 'risk' ? thresholds.dontShipAbove : thresholds.icePackAbove);
      var el = document.createElement('div');
      el.className = 'ssa-weather__day ssa-weather__day--' + d.classification +
                     (isColdDay ? ' ssa-weather__day--cold' : '') +
                     (isTransit ? ' ssa-weather__day--transit' : '');
      el.innerHTML =
        '<div class="ssa-weather__day-body">' +
          '<div class="ssa-weather__day-name">' + fmt.day + '</div>' +
          '<div class="ssa-weather__day-high">' + high + '°</div>' +
          '<div class="ssa-weather__day-low">'  + low  + '°</div>' +
        '</div>' +
        '<div class="ssa-weather__day-footer">' + fmt.dateNum + '</div>';
      gridEl.appendChild(el);
    });

    if (shipDateObj && deliveryDays.length > 0) {
      renderShippingWeek(shipDateObj, deliveryDays, data.shipNote || null, data.shipRestriction || null, thresholds);
      renderPackRecommendation(deliveryDays);
    } else {
      shippingWeekEl.innerHTML = '';
      packEl.hidden = true;
      packEl.innerHTML = '';
    }

    if (disclaimerEl) {
      var sources = (data.sources || []).join(' + ');
      disclaimerEl.textContent =
        'Forecasts within 7 days use averaged ' + sources + ' data. Beyond 7 days, Open-Meteo only — accuracy decreases with time. ' +
        'Temperatures shown are estimates and may differ from actual conditions at your address. ' +
        'Pack recommendations are based on forecasted averages across your delivery window and are guidance only. ' +
        'We make final shipping decisions at time of packing and will reach out if conditions warrant a delay or hold.';
    }

    resultsEl.hidden = false;
  }

  function lookup(zip) {
    clearError();
    setLoading(true);
    resultsEl.hidden = true;

    fetchWeather(zip).then(function(data) {
      try {
        renderForecast(data);
        try { localStorage.setItem(STORAGE_KEY, zip); } catch(e) {}
      } catch(renderErr) {
        console.error('SSA Weather render error:', renderErr);
        throw new Error('Forecast loaded but could not be displayed. Please refresh and try again.');
      }
    }).catch(function(err) {
      console.error('SSA Weather error:', err);
      showError(err.message || 'Unable to load forecast. Please try again.');
    }).then(function() {
      setLoading(false);
    });
  }

  form.addEventListener('submit', function(e) {
    e.preventDefault();
    var zip = input.value.trim();
    if (!/^\d{5}$/.test(zip)) { showError('Please enter a valid 5-digit US ZIP code.'); return; }
    lookup(zip);
  });

  changeBtn.addEventListener('click', function() {
    resultsEl.hidden = true;
    input.focus();
    input.select();
  });

  try {
    var saved = localStorage.getItem(STORAGE_KEY);
    if (saved && /^\d{5}$/.test(saved)) { input.value = saved; lookup(saved); }
  } catch(e) {}
})();
</script>

{%- endif -%}
